// Prisma schema for SEO Analytics Dashboard
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Пользователи админки (вход по логину+паролю)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin") // admin | editor | viewer
  createdAt    DateTime @default(now())
}

// Сайт — источник трафика (Яндекс.Метрика)
model Site {
  id              String        @id @default(cuid())
  name            String
  domain          String
  metrikaCounter  String?       // ID счётчика Яндекс.Метрики
  color           String        @default("#3b82f6") // цвет на графиках
  createdAt       DateTime      @default(now())
  traffic         TrafficData[]
  projects        Project[]
}

// Проект — единица отслеживания видимости (Топвизор)
model Project {
  id               String           @id @default(cuid())
  name             String
  topvisorId       String?          // ID проекта в Топвизоре
  searchEngine     String           @default("Яндекс") // Яндекс | Google
  region           String?          // регион проверки позиций
  color            String           @default("#10b981")
  site             Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteId           String?
  createdAt        DateTime         @default(now())
  visibility       VisibilityData[]
}

// Дневные данные по трафику из Метрики
model TrafficData {
  id          String   @id @default(cuid())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  date        DateTime @db.Date
  visits      Int      @default(0)
  visitors    Int      @default(0)
  pageviews   Int      @default(0)
  bounceRate  Float    @default(0) // %
  avgDuration Int      @default(0) // секунды
  source      String   @default("all") // all | organic | direct | referral | social | ads

  @@unique([siteId, date, source])
  @@index([siteId, date])
}

// Недельная сводка по лидам из CRM (Bitrix) — агрегат по неделя × проект.
// Уникальный лид = уникальный контакт (мобильный клиента или визит metrika).
// Источники: значения разнесены по полям UTM(×2)+Источник(×2)+Система+Реферер+Директ;
// нераспознанный источник делится 60% SEO / 40% рекомендации.
model LeadStat {
  id          String   @id @default(cuid())
  weekStart   DateTime @db.Date // понедельник недели
  weekLabel   String           // напр. "17–23.06" для подписи
  project     String           // Easypay.World | 4YouCards | VisaMasterCards | AVO.cards | Visatut
  val         Int      @default(0) // вал (уникальные лиды)
  qual        Int?             // кач-лиды (из DEAL), null = ещё не посчитано
  seo         Int      @default(0)
  recom       Int      @default(0) // рекомендации/прямые
  direct      Int      @default(0) // Яндекс.Директ
  klerk       Int      @default(0)
  insta       Int      @default(0)
  karty       Int      @default(0)
  dzen        Int      @default(0)
  youtube     Int      @default(0)
  partner     Int      @default(0)
  seoGoogle   Int      @default(0) // SEO-сплит: гугл
  seoYandex   Int      @default(0) // SEO-сплит: яндекс
  seoUnknown  Int      @default(0) // SEO-сплит: неизвестно/распределённое
  updatedAt   DateTime @updatedAt

  @@unique([weekStart, project])
  @@index([weekStart])
}

// Оплаченная продажа карты из CRM (DEAL). «Чек» = поле «Оплаченная сумма» / «Оплачено».
model CardSale {
  id        String   @id @default(cuid())
  dealId    String   @unique // ID сделки в Bitrix (идемпотентный импорт)
  date      DateTime @db.Date // дата создания сделки
  amount    Int      @default(0) // оплаченная сумма, ₽
  cardType  String?          // «Тип карты» (виртуальная, Бакай голд…)
  bank      String?          // нормализованный банк (Бакай/Ориён/Арцах/…)
  product   String?          // «Товар» (полное название карты)
  source    String?          // источник продажи (SEO/Директ/…), если определён
  project   String?          // проект
  isImport  Boolean  @default(false) // true = из миграции истории (25–28.05), не «живая»
  createdAt DateTime @default(now())

  @@index([date])
  @@index([isImport])
}

// Дневные данные по видимости из Топвизора
model VisibilityData {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  date         DateTime @db.Date
  searchEngine String   @default("Яндекс") // Яндекс | Google
  visibility   Float    @default(0) // % видимости
  avgPosition  Float    @default(0) // средняя позиция
  top3         Int      @default(0) // кол-во запросов в ТОП-3
  top10        Int      @default(0) // кол-во запросов в ТОП-10
  top50        Int      @default(0) // кол-во запросов в ТОП-50
  queriesTotal Int      @default(0) // всего запросов в проекте

  @@unique([projectId, date, searchEngine])
  @@index([projectId, date, searchEngine])
}
