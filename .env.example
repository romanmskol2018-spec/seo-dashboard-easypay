# Скопируй в .env и заполни своими значениями

# Neon Postgres (https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Секрет для подписи сессий (сгенерируй: openssl rand -hex 32)
JWT_SECRET="замени-на-случайную-строку"

# Учётка первого администратора (для сидера)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"
ADMIN_NAME="Администратор"

# API-ключи (добавим на этапе интеграции)
# TOPVISOR_API_KEY=""
# TOPVISOR_USER=""
# YANDEX_METRIKA_TOKEN=""
